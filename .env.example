# =============================================================================
# DocAI — Environment Variables
# =============================================================================
# Copy this to .env.local and fill in your values.
# Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE — https://supabase.com (free tier, no credit card needed)
# Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Server-only, never expose client-side

# -----------------------------------------------------------------------------
# GROQ — https://console.groq.com (free tier, ~14,400 reqs/day)
# Models: llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768
# -----------------------------------------------------------------------------
GROQ_API_KEY=gsk_your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# -----------------------------------------------------------------------------
# HUGGING FACE — https://huggingface.co/settings/tokens (free tier)
# Used for: sentence-transformers/all-MiniLM-L6-v2 embeddings (384-dim)
# Inference API: 1000 req/day free, enough for dev. Self-hosted = unlimited.
# -----------------------------------------------------------------------------
HUGGINGFACE_API_KEY=hf_your-token-here
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# -----------------------------------------------------------------------------
# APP CONFIG
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=DocAI

# In production (Vercel free tier), set this to your deployment URL:
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# -----------------------------------------------------------------------------
# OPTIONAL — Redis (only if using rate-limiting or session caching)
# Docker Compose spins one up free locally. Upstash Redis has a free tier too.
# Leave blank to disable Redis features gracefully.
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# OPTIONAL — Document processing limits
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_MB=10
MAX_DOCUMENTS_PER_USER=50
CHUNK_SIZE=500
CHUNK_OVERLAP=50
